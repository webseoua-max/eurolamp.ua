icy.<\/a><\/span>":["<span>\u0414\u043e\u043f\u043e\u043c\u043e\u0436\u0456\u0442\u044c \u043d\u0430\u043c \u043f\u043e\u043a\u0440\u0430\u0449\u0438\u0442\u0438 Site Kit, \u043f\u043e\u0434\u0456\u043b\u0438\u0432\u0448\u0438\u0441\u044c \u0430\u043d\u043e\u043d\u0456\u043c\u043d\u0438\u043c\u0438 \u0434\u0430\u043d\u0438\u043c\u0438 \u043f\u0440\u043e \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f.<\/span> <span>\u0423\u0441\u0456 \u0437\u0456\u0431\u0440\u0430\u043d\u0456 \u0434\u0430\u043d\u0456 \u043e\u0431\u0440\u043e\u0431\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u043d\u043e \u0434\u043e <a>\u041f\u043e\u043b\u0456\u0442\u0438\u043a\u0438 \u043a\u043e\u043d\u0444\u0456\u0434\u0435\u043d\u0446\u0456\u0439\u043d\u043e\u0441\u0442\u0456 Google.<\/a><\/span>"],"Google Account (Email: %1$s)":["\u041e\u0431\u043b\u0456\u043a\u043e\u0432\u0438\u0439 \u0437\u0430\u043f\u0438\u0441 Google (\u0415\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0430 \u0430\u0434\u0440\u0435\u0441\u0430: %1$s)"],"Google Account for %1$s":["\u041e\u0431\u043b\u0456\u043a\u043e\u0432\u0438\u0439 \u0437\u0430\u043f\u0438\u0441 Google \u0434\u043b\u044f %1$s"],"Google Account for %1$s (Email: %2$s)":["\u041e\u0431\u043b\u0456\u043a\u043e\u0432\u0438\u0439 \u0437\u0430\u043f\u0438\u0441 Google \u0434\u043b\u044f %1$s (\u0415\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0430 \u0430\u0434\u0440\u0435\u0441\u0430: %2$s)"],"Copied to clipboard":["\u0421\u043a\u043e\u043f\u0456\u0439\u043e\u0432\u0430\u043d\u043e \u0432 \u0431\u0443\u0444\u0435\u0440 \u043e\u0431\u043c\u0456\u043d\u0443"],"Please select at least 1 answer":["\u0411\u0443\u0434\u044c \u043b\u0430\u0441\u043a\u0430, \u0432\u0438\u0431\u0435\u0440\u0456\u0442\u044c \u0445\u043e\u0447\u0430 \u0431 1 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c"],"Please select an answer":["\u0411\u0443\u0434\u044c \u043b\u0430\u0441\u043a\u0430, \u0432\u0438\u04